[Unit]
Description=rtesip SIP Codec
After=network-online.target
Wants=network-online.target
StartLimitBurst=5
StartLimitIntervalSec=60

[Service]
Type=simple
User=rtesip
Group=rtesip
SupplementaryGroups=audio netdev
WorkingDirectory=/opt/rtesip
ExecStartPre=+/opt/rtesip/deploy/scripts/detect-audio.sh
ExecStartPre=+/usr/sbin/rfkill unblock wifi
ExecStartPre=+/usr/sbin/ip link set wlan0 up
ExecStart=/opt/rtesip/.venv/bin/python run.py
Restart=always
RestartSec=3
TimeoutStopSec=15
# WatchdogSec=30  # TODO: implement sd_notify watchdog pings
EnvironmentFile=-/etc/rtesip/env

# Hardening
ProtectSystem=full
ReadWritePaths=/var/lib/rtesip /run/rtesip /boot /var/log/rtesip
NoNewPrivileges=true
ProtectHome=true
# PrivateTmp=true  # Disabled — wpa_cli needs shared /tmp for response socket
ProtectKernelTunables=true
ProtectKernelModules=true
ProtectControlGroups=true

# Capabilities for port 80 and RT audio
AmbientCapabilities=CAP_NET_BIND_SERVICE CAP_SYS_NICE CAP_NET_ADMIN

# RT priority for audio subprocess
LimitRTPRIO=99
LimitMEMLOCK=infinity

[Install]
WantedBy=multi-user.target
